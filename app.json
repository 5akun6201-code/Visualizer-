{
  "expo": {
    "extra": {
      "eas": {
        "projectId": "385fb6e5-65bf-485f-9667-0ceceb513471"
      }
    },
    "name": "VisualBeat",
    "slug": "visualbeat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.visualbeat.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      "expo-av",
      "expo-document-picker",
      [
        "expo-image-picker",
        { "photosPermission": "Izinkan VisualBeat akses galeri." }
      ],
      [
        "expo-media-library",
        { "photosPermission": "Izinkan VisualBeat simpan video ke galeri." }
      ]
    ]
  }
}
